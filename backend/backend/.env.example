PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db
ADS_REQUIRE_DB=false
CORS_ORIGIN=*

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
HUGGINGFACE_API_KEY=your_huggingface_api_key
HUGGINGFACE_IMAGE_ENDPOINT=https://router.huggingface.co/together/v1/images/generations
HUGGINGFACE_IMAGE_MODEL=Qwen/Qwen-Image
HUGGINGFACE_IMAGE_SIZE=1024x1024
HF_CREDIT_COOLDOWN_MINUTES=30

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=ads
